{
  "name": "praja-connect-crm",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "database"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@praja/web --filter=@praja/api",
    "build:libs": "npm run build -w @praja/types && npm run build -w @praja/database",
    "build": "npm run build:libs && npm run build -w @praja/api && npm run build -w @praja/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run build:libs && npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @praja/database",
    "db:migrate": "npm run db:migrate -w @praja/database",
    "db:seed": "npm run db:seed -w @praja/database",
    "db:reset": "npm run db:reset -w @praja/database",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "react-native": "0.81.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "react-native": "0.81.5",
    "react-native-reanimated": "4.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
