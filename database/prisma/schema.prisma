// ============================================================
// Assets Management
// ============================================================
model Asset {
  id          String          @id @default(cuid())
  category    AssetCategory
  name        String
  code        String          @unique
  description String?
  status      AssetStatus     @default(Active)
  condition   AssetCondition?
  contractor  String?

  latitude  Float?
  longitude Float?
  address   String?

  wardNumber     String?
  villageId      String?
  village        Village?            @relation(fields: [villageId], references: [id])
  mandalId       String?
  mandal         Mandal?             @relation(fields: [mandalId], references: [id])
  constituencyId String?
  constituency   Constituency?       @relation(fields: [constituencyId], references: [id])
  departmentId   String?
  department     Department?         @relation(fields: [departmentId], references: [id])
  projectId      String?
  project        DevelopmentProject? @relation(fields: [projectId], references: [id])

  /// Category-specific attributes for categories without a dedicated detail table.
  attributes Json?

  createdById String?

  road       RoadAsset?
  hospital   HospitalAsset?
  school     SchoolAsset?
  rws        RwsAsset?
  photos     AssetPhoto[]
  documents  AssetDocument[]
  logs       AssetMaintenanceLog[]
  grievances Grievance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([mandalId])
  @@index([villageId])
  @@index([constituencyId])
  @@index([createdAt])
  @@map("assets")
}

