  @@index([priority])
  @@index([dueAt])
  @@index([scheduledAt])
  @@index([assignedToUserId])
  @@index([citizenId])
  @@index([cadreId])
  @@index([campaignId])
  @@index([grievanceId])
  @@index([mandalId])
  @@index([constituencyId])
  @@index([createdAt])
}

