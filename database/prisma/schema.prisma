  longitude     Float?

  campaignId String?
  campaign   ActivityCampaign? @relation(fields: [campaignId], references: [id])

  citizenId   String?
  citizen     Citizen?            @relation(fields: [citizenId], references: [id])
  cadreId     String?
  cadre       Cadre?              @relation(fields: [cadreId], references: [id])
