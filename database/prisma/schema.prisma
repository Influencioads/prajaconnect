// Praja Connect CRM - full domain schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================
enum UserRole {
  SuperAdmin
  StateLeader
  DistrictLeader
  ConstituencyIncharge
  MandalCoordinator
  BoothCoordinator
  Volunteer
  GovernmentOfficial
  Citizen
}

enum UserStatus {
  Active
  Inactive
  Suspended
}

enum AccessLevel {
  none
  view
  edit
  full
}

enum CadreStatus {
  Active
  OnLeave
  Inactive
}

enum Gender {
  Male
  Female
  Other
}

enum CitizenStatus {
  Active
  Inactive
  Deceased
  Migrated
}

enum GrievanceChannel {
  WhatsApp
  Voice
  Field
  Web
  Mobile
}

enum GrievancePriority {
  High
  Medium
  Low
}

enum GrievanceStatus {
  Open
  Assigned
  InProgress
  Escalated
  Resolved
  Closed
}

enum GrievanceSlaViolationType {
  Validation
  Resolution
}

enum GrievanceSlaViolationStatus {
  Open
  Resolved
}

enum TempGrievanceSource {
  Call
  CampaignCall
  ConferenceCall
  WhatsApp
  WhatsAppBot
  D2DSurvey
  Email
  SMS
  FieldVisit
  VolunteerNote
  Manual
}

enum TempGrievanceStatus {
  New
  PendingValidation
  MoreInfoRequired
  Validated
  Converted
  Duplicate
  Rejected
  Archived
}

enum TempGrievancePriority {
  Low
  Medium
  High
  Critical
}

enum DuplicateRisk {
  None
  Low
  Medium
  High
}

enum BeneficiaryStatus {
  Enrolled
  Pending
  Rejected
  Disbursed
}

enum SchemeStatus {
  Active
  Upcoming
  Closed
}

enum ProjectStatus {
  Planning
  InProgress
  Completed
  Delayed
}

enum EventType {
  Rally
  Camp
  Meeting
  Awareness
  Other
}

enum EventStatus {
  Scheduled
  Ongoing
  Completed
  Cancelled
}

enum SurveyStatus {
  Draft
  Active
  Closed
}

enum NotificationType {
  Info
  Warning
  Alert
  Success
}

enum WhatsAppDirection {
  Inbound
  Outbound
}

enum WhatsAppStatus {
  Queued
  Sent
  Delivered
  Read
  Failed
}

enum AuditAction {
  Login
  Logout
  Create
  Update
  Delete
  Export
  Assign
  Escalate
}

enum OfficialLevel {
  Booth
  Village
  Mandal
  Constituency
  District
  State
}

enum ActivityType {
  Call
  CampaignCall
  ConferenceCall
  WhatsApp
  Email
  Meeting
  Visit
  Task
  VolunteerActivity
  CadreActivity
  GrievanceFollowup
  EventActivity
  SurveyActivity
  SocialMedia
  PressInteraction
  InfluencerInteraction
  OfficialMeeting
  FieldVisit
  DoorToDoor
  BoothActivity
  SmsCampaign
  VoiceBroadcast
}

enum ActivityStatus {
  Planned
  Scheduled
  InProgress
  Completed
  Cancelled
  NoResponse
  FollowUp
}

enum ActivityDirection {
  Inbound
  Outbound
  Missed
}

enum ActivityPriority {
  High
  Medium
  Low
}

enum CampaignType {
  CampaignCall
  SmsCampaign
  VoiceBroadcast
  EmailCampaign
  DoorToDoor
  FieldOutreach
}

enum CampaignStatus {
  Draft
  Active
  Paused
  Completed
  Cancelled
}

enum ParticipantStatus {
  Invited
  Confirmed
  Attended
  Absent
  Declined
}

enum CommitteeCategory {
  MandalCommittee
  VillageCommittee
  CoordinationCommittee
  MandalCoordinationCommittee
}

enum NetworkStatus {
  Active
  Inactive
}

enum NetworkEntityType {
  CommitteeMember
  Observer
  ImpLeader
  Influencer
  Press
}

enum JournalistType {
  Print
  TV
  Digital
  YouTube
}

enum AssetCategory {
  Roads
  Taxes
  ReligiousPlaces
  DevelopmentWorks
  DealerShops
  BurialGrounds
  Hospitals
  Schools
  DwcraGroups
  Tanks
  RwsAssets
  GreenAmbassadors
  GovernmentOffices
}

enum AssetStatus {
  Active
  Inactive
  UnderMaintenance
  UnderDevelopment
  Decommissioned
}

enum AssetCondition {
  Good
  Fair
  Damaged
  Critical
}

enum D2DSurveyType {
  Household
  Voter
  Scheme
  Grievance
  ElectionSentiment
  CandidateFeedback
  DevelopmentWorks
}

enum D2DSurveyStatus {
  Draft
  Active
  Paused
  Completed
  Closed
}

enum D2DQuestionType {
  Text
  Number
  SingleChoice
  MultiChoice
  YesNo
  Rating
  Dropdown
  Photo
  Location
  Signature
}

enum D2DSentiment {
  Supporter
  Neutral
  Opponent
  Undecided
}

enum D2DPriority {
  High
  Medium
  Low
}

enum D2DSyncStatus {
  Pending
  Synced
  Failed
}

enum D2DAssignmentStatus {
  Active
  Paused
  Completed
}

enum D2DResponseStatus {
  Draft
  Submitted
  Synced
  Failed
}

// ============================================================
// Geography
// ============================================================
model State {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  districts District[]
  createdAt DateTime   @default(now())
}

model District {
  id             String         @id @default(cuid())
  name           String
  code           String         @unique
  stateId        String
  state          State          @relation(fields: [stateId], references: [id])
  constituencies Constituency[]
  createdAt      DateTime       @default(now())

  @@index([stateId])
}

model Constituency {
  id         String   @id @default(cuid())
  name       String
  number     Int?
  type       String   @default("Assembly")
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  mandals    Mandal[]

  users      User[]
  cadres     Cadre[]
  citizens   Citizen[]
  grievances Grievance[]
  events     Event[]
  projects   DevelopmentProject[]
  activities Activity[]
  campaigns  ActivityCampaign[]
  assets     Asset[]
  d2dSurveys D2DSurvey[]
  elections  Election[]
  createdAt  DateTime             @default(now())

  @@index([districtId])
}

model Mandal {
  id             String       @id @default(cuid())
  name           String
  constituencyId String
  constituency   Constituency @relation(fields: [constituencyId], references: [id])
  villages       Village[]

  users      User[]
  cadres     Cadre[]
  citizens   Citizen[]
  grievances Grievance[]
  tempGrievances TemporaryGrievance[]
  events     Event[]
  projects   DevelopmentProject[]
  activities Activity[]
  campaigns  ActivityCampaign[]

  committees       Committee[]
  committeeMembers CommitteeMember[]
  observers        Observer[]
  impLeaders       ImpLeader[]
  influencers      Influencer[]
  pressContacts    PressContact[]
  assets           Asset[]
  d2dSurveys       D2DSurvey[]
  d2dHouseholds    D2DHousehold[]
  electionExpenses ElectionExpense[]
  electionWorks    ElectionCampaignWork[]
  electionVehicleAssignments ElectionVehicleAssignment[]
  electionOutreach ElectionVoterOutreach[]
  electionTeams    ElectionCampaignTeam[]
  electionMaterialDistributions ElectionMaterialDistribution[]

  warRoomAlerts       WarRoomAlert[]
  mandalReadiness     MandalReadinessScore?
  electionEscalations ElectionEscalation[]
  geoFenceZones       GeoFenceZone[]
  crisisIssues        CrisisIssue[]

  createdAt DateTime @default(now())

  @@index([constituencyId])
}

model Village {
  id         String               @id @default(cuid())
  name       String
  pincode    String?
  mandalId   String
  mandal     Mandal               @relation(fields: [mandalId], references: [id])
  booths     Booth[]
  families   Family[]
  citizens   Citizen[]
  grievances Grievance[]
  tempGrievances TemporaryGrievance[]
  events     Event[]
  projects   DevelopmentProject[]
  activities Activity[]

  committees       Committee[]
  committeeMembers CommitteeMember[]
  observers        Observer[]
  impLeaders       ImpLeader[]
  influencers      Influencer[]
  pressContacts    PressContact[]
  assets           Asset[]
  d2dSurveys       D2DSurvey[]
  d2dHouseholds    D2DHousehold[]
  electionExpenses ElectionExpense[]
  electionWorks    ElectionCampaignWork[]
  electionVehicleAssignments ElectionVehicleAssignment[]
  electionOutreach ElectionVoterOutreach[]
  electionTeams    ElectionCampaignTeam[]
  electionMaterialDistributions ElectionMaterialDistribution[]

  crisisIssues   CrisisIssue[]
  sensitiveAreas SensitiveArea[]

  createdAt DateTime @default(now())

  @@index([mandalId])
}

model Booth {
  id         String     @id @default(cuid())
  number     String
  name       String?
  voterCount Int        @default(0)
  villageId  String
  village    Village    @relation(fields: [villageId], references: [id])
  families   Family[]
  cadres     Cadre[]
  citizens   Citizen[]
  activities Activity[]
  tempGrievances TemporaryGrievance[]

  committees       Committee[]
  committeeMembers CommitteeMember[]
  observers        Observer[]
  impLeaders       ImpLeader[]
  influencers      Influencer[]
  pressContacts    PressContact[]
  d2dSurveys       D2DSurvey[]
  d2dHouseholds    D2DHousehold[]
  electionExpenses ElectionExpense[]
  electionWorks    ElectionCampaignWork[]
  electionVehicleAssignments ElectionVehicleAssignment[]
  electionOutreach ElectionVoterOutreach[]
  electionTeams    ElectionCampaignTeam[]
  electionMaterialDistributions ElectionMaterialDistribution[]
  electionBoothPlans ElectionBoothPlan[]
  boothVoterStrength BoothVoterStrength?
  electoralRollEntries ElectoralRollEntry[]
  warRoomAlerts        WarRoomAlert[]
  boothReadiness       BoothReadinessScore?

  createdAt DateTime @default(now())

  @@index([villageId])
}

model Family {
  id         String    @id @default(cuid())
  headName   String
  address    String?
  rationCard String?
  villageId  String?
  village    Village?  @relation(fields: [villageId], references: [id])
  boothId    String?
  booth      Booth?    @relation(fields: [boothId], references: [id])
  members    Citizen[]
  d2dHouseholds D2DHousehold[]
  familyVoterPreference FamilyVoterPreference?
  createdAt  DateTime  @default(now())

  @@index([villageId])
  @@index([boothId])
}

// ============================================================
// People & access
// ============================================================
model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  label       String
  rank        Int              @default(0)
  description String?
  isSystem    Boolean          @default(false)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id        String           @id @default(cuid())
  module    String           @unique
  label     String
  roles     RolePermission[]
  createdAt DateTime         @default(now())
}

model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  accessLevel  AccessLevel @default(view)
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  mobile         String         @unique
  passwordHash   String
  roleId         String
  role           Role           @relation(fields: [roleId], references: [id])
  status         UserStatus     @default(Active)
  language       String         @default("en")
  designation    String?
  photo          String?
  constituencyId String?
  constituency   Constituency?  @relation(fields: [constituencyId], references: [id])
  mandalId       String?
  mandal         Mandal?        @relation(fields: [mandalId], references: [id])
  lastLoginAt    DateTime?
  refreshTokens  RefreshToken[]
  cadreProfile   Cadre?
  notifications  Notification[]

  assignedActivities     Activity[]            @relation("ActivityAssignee")
  createdActivities      Activity[]            @relation("ActivityCreator")
  activityParticipations ActivityParticipant[]
  activityReminders      ActivityReminder[]

  createdCommitteeMembers CommitteeMember[]
  createdObservers        Observer[]
  createdImpLeaders       ImpLeader[]
  createdInfluencers      Influencer[]
  createdPressContacts    PressContact[]
  committeeActivityLogs   CommitteeActivityLog[]

  createdD2DSurveys       D2DSurvey[]           @relation("D2DSurveyCreator")
  d2dAssignments          D2DSurveyAssignment[]
  d2dResponses            D2DSurveyResponse[]   @relation("D2DResponseSurveyor")
  d2dVolunteerTargets     D2DVolunteerTarget[]
  d2dFollowups            D2DFollowup[]
  d2dHouseholdsSurveyed   D2DHousehold[]        @relation("D2DHouseholdSurveyor")

  createdTempGrievances     TemporaryGrievance[] @relation("TempGrievanceCreator")
  assignedTempGrievances    TemporaryGrievance[] @relation("TempGrievanceValidator")
  tempGrievanceNotes        TemporaryGrievanceNote[]
  tempGrievanceValidationLogs TemporaryGrievanceValidationLog[]
  tempGrievanceMedia        TemporaryGrievanceMedia[]

  createdElectionExpenses     ElectionExpense[] @relation("ElectionExpenseCreator")
  approvedElectionExpenses    ElectionExpenseApproval[] @relation("ElectionExpenseApprover")
  createdElectionWorks        ElectionCampaignWork[] @relation("ElectionWorkCreator")
  createdElectionTrips        ElectionVehicleTripLog[] @relation("ElectionTripCreator")
  createdElectionFuelLogs     ElectionVehicleFuelLog[] @relation("ElectionFuelCreator")
  createdElectionOutreach     ElectionVoterOutreach[] @relation("ElectionOutreachCreator")
  createdElectionMaterials    ElectionMaterialDistribution[] @relation("ElectionMaterialDistributor")
  createdElectionPollingUpdates ElectionPollingDayUpdate[] @relation("ElectionPollingUpdater")
  generatedElectionReports    ElectionReport[] @relation("ElectionReportGenerator")
  voterImportBatches          VoterImportBatch[]
  reviewedVoterDuplicates     VoterDuplicateCandidate[]
  voterIntelligenceChangeLogs VoterIntelligenceChangeLog[]

  dailyBriefings              DailyBriefing[] @relation("DailyBriefingCreator")
  assignedEscalations         ElectionEscalation[] @relation("EscalationAssignee")
  warRoomActivities           WarRoomActivityFeed[] @relation("WarRoomActivityUser")
  attendanceCorrectionsReviewed AttendanceCorrectionRequest[] @relation("AttendanceCorrectionReviewer")
  crisisTimelineEntries       CrisisTimelineEntry[] @relation("CrisisTimelineUser")
  crisisEscalationAssignments CrisisEscalation[] @relation("CrisisEscalationAssignee")
  documentAccessLogs          DocumentAccessLog[] @relation("DocumentAccessUser")
  callAgentProfile            CallAgent? @relation("CallAgentUser")
  mergeReviews                ProfileMergeSuggestion[] @relation("MergeReviewer")
  officeStaffAssignments      OfficeStaffAssignment[] @relation("OfficeStaffUser")
  loginHistories              LoginHistory[] @relation("LoginHistoryUser")
  roleActivityLogs            RoleActivityLog[] @relation("RoleActivityUser")
  dataExportLogs              DataExportLog[] @relation("DataExportUser")
  fileAccessLogs              FileAccessLog[] @relation("FileAccessUser")
  userSessions                UserSession[] @relation("UserSessionUser")
  acknowledgedPrAlerts        PrAlert[] @relation("PrAlertAcknowledger")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([status])
  @@index([constituencyId])
  @@index([mandalId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model OtpToken {
  id        String   @id @default(cuid())
  mobile    String
  code      String
  purpose   String   @default("login")
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mobile])
}

model Cadre {
  id          String        @id @default(cuid())
  name        String
  mobile      String
  email       String?
  designation String
  level       OfficialLevel @default(Booth)
  status      CadreStatus   @default(Active)
  photo       String?
  address     String?
  joinedAt    DateTime      @default(now())
  performance Int           @default(0)
  notes       String?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  parentId String?
  parent   Cadre?  @relation("CadreHierarchy", fields: [parentId], references: [id])
  children Cadre[] @relation("CadreHierarchy")

  constituencyId String?
  constituency   Constituency? @relation(fields: [constituencyId], references: [id])
  mandalId       String?
  mandal         Mandal?       @relation(fields: [mandalId], references: [id])
  boothId        String?
  booth          Booth?        @relation(fields: [boothId], references: [id])

  assignedGrievances     Grievance[]           @relation("GrievanceCadre")
  organizedEvents        Event[]               @relation("EventOrganizer")
  activities             Activity[]
  activityParticipations ActivityParticipant[]

  reportingCommitteeMembers CommitteeMember[]
  reportingObservers        Observer[]
  reportingImpLeaders       ImpLeader[]
  reportingInfluencers      Influencer[]
  reportingPressContacts    PressContact[]

  d2dAssignments D2DSurveyAssignment[]
  d2dResponses   D2DSurveyResponse[]
  d2dTargets     D2DVolunteerTarget[]

  electionWorkAssignments ElectionWorkAssignment[]
  ledElectionTeams        ElectionCampaignTeam[] @relation("ElectionTeamLeader")
  electionTeamMemberships ElectionTeamMember[]
  electionPollingAgents   ElectionPollingAgent[]
  electionMaterialIssues  ElectionMaterialDistribution[]

  volunteerAttendances      VolunteerAttendance[]
  fieldRoutePoints          FieldRoutePoint[]
  dailyFieldReports         DailyFieldReport[]
  rapidResponseAssignments  RapidResponseAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([constituencyId])
  @@index([mandalId])
  @@index([boothId])
  @@index([parentId])
}

model Citizen {
  id            String        @id @default(cuid())
  name          String
  mobile        String?
  gender        Gender?
  dob           DateTime?
  age           Int?
  voterId       String?
  aadhaarMasked String?
  occupation    String?
  category      String?
  address       String?
  status        CitizenStatus @default(Active)
  notes         String?

  familyId     String?
  family       Family? @relation(fields: [familyId], references: [id])
  isFamilyHead Boolean @default(false)

  villageId      String?
  village        Village?      @relation(fields: [villageId], references: [id])
  boothId        String?
  booth          Booth?        @relation(fields: [boothId], references: [id])
  mandalId       String?
  mandal         Mandal?       @relation(fields: [mandalId], references: [id])
  constituencyId String?
  constituency   Constituency? @relation(fields: [constituencyId], references: [id])

  grievances             Grievance[]
  temporaryGrievances    TemporaryGrievance[]
  beneficiaries          Beneficiary[]
  eventAttendees         EventAttendee[]
  surveyResponses        SurveyResponse[]
  conversations          WhatsappConversation[]
  activities             Activity[]
  activityParticipations ActivityParticipant[]
  d2dFamilyMembers       D2DFamilyMember[]
  d2dHouseholds          D2DHousehold[]
  electionOutreach       ElectionVoterOutreach[]
  electionPollingAgents  ElectionPollingAgent[]

  voterIntelligenceProfile VoterIntelligenceProfile?
  electoralRollMatches     ElectoralRollEntry[]
  voterDuplicatesA         VoterDuplicateCandidate[] @relation("VoterDuplicateA")
  voterDuplicatesB         VoterDuplicateCandidate[] @relation("VoterDuplicateB")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([mandalId])
  @@index([constituencyId])
  @@index([boothId])
  @@index([villageId])
  @@index([familyId])
  @@index([voterId])
}

// ============================================================
// Service delivery
// ============================================================
model Department {
  id          String               @id @default(cuid())
  name        String               @unique
  category    String?
  description String?
  slaHours    Int                  @default(72)
  officials   GovernmentOfficial[]
  grievances  Grievance[]
  projects    DevelopmentProject[]
  assets      Asset[]
  createdAt   DateTime             @default(now())
}

model GovernmentOfficial {
  id              String        @id @default(cuid())
  name            String
  designation     String
  level           OfficialLevel @default(Mandal)
  mobile          String?
  email           String?
  office          String?
  jurisdiction    String?
  escalationOrder Int           @default(1)
  photo           String?
  departmentId    String?
  department      Department?   @relation(fields: [departmentId], references: [id])
  grievances      Grievance[]   @relation("GrievanceOfficial")
  activities      Activity[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([departmentId])
  @@index([level])
}

model Grievance {
  id          String            @id @default(cuid())
  code        String            @unique
  title       String
  description String
  category    String?
  channel     GrievanceChannel  @default(Web)
  priority    GrievancePriority @default(Medium)
  status      GrievanceStatus   @default(Open)

  citizenId        String?
  citizen          Citizen? @relation(fields: [citizenId], references: [id])
  reportedByName   String?
  reportedByMobile String?

  departmentId       String?
  department         Department?         @relation(fields: [departmentId], references: [id])
  assignedOfficialId String?
  assignedOfficial   GovernmentOfficial? @relation("GrievanceOfficial", fields: [assignedOfficialId], references: [id])
  assignedCadreId    String?
  assignedCadre      Cadre?              @relation("GrievanceCadre", fields: [assignedCadreId], references: [id])

  villageId      String?
  village        Village?      @relation(fields: [villageId], references: [id])
  mandalId       String?
  mandal         Mandal?       @relation(fields: [mandalId], references: [id])
  constituencyId String?
  constituency   Constituency? @relation(fields: [constituencyId], references: [id])

  address   String?
  latitude  Float?
  longitude Float?
  photoUrl  String?

  slaDueAt           DateTime?
  slaDays            Int?
  resolvedAt         DateTime?
  satisfactionRating Int?
  feedback           String?

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  createdById           String?
  convertedFromTempId   String?             @unique
  convertedFromTemp     TemporaryGrievance? @relation("ConvertedGrievance", fields: [convertedFromTempId], references: [id])
  updates               GrievanceUpdate[]
  activities            Activity[]
  committeeActivityLogs CommitteeActivityLog[]
  d2dResponses          D2DSurveyResponse[]
  slaViolations         GrievanceSlaViolation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([departmentId])
  @@index([assignedOfficialId])
  @@index([assignedCadreId])
  @@index([mandalId])
  @@index([constituencyId])
  @@index([citizenId])
  @@index([assetId])
  @@index([createdAt])
}

model GrievanceUpdate {
  id          String           @id @default(cuid())
  grievanceId String
  grievance   Grievance        @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  action      String
  fromStatus  GrievanceStatus?
  toStatus    GrievanceStatus?
  note        String?
  byUserId    String?
  byName      String?
  createdAt   DateTime         @default(now())

  @@index([grievanceId])
}

model GrievanceSlaViolation {
  id              String                      @id @default(cuid())
  type            GrievanceSlaViolationType
  grievanceId     String?
  grievance       Grievance?                  @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  tempGrievanceId String?
  tempGrievance   TemporaryGrievance?         @relation(fields: [tempGrievanceId], references: [id], onDelete: Cascade)
  slaDueAt        DateTime
  breachedAt      DateTime                    @default(now())
  overdueDays     Int
  status          GrievanceSlaViolationStatus @default(Open)
  dedupeKey       String                      @unique
  lastNotifiedAt  DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([type])
  @@index([status])
  @@index([grievanceId])
  @@index([tempGrievanceId])
  @@index([overdueDays])
}

model Scheme {
  id            String        @id @default(cuid())
  name          String
  code          String        @unique
  category      String?
  description   String?
  department    String?
  eligibility   Json?
  benefitAmount Float?
  startDate     DateTime?
  endDate       DateTime?
  status        SchemeStatus  @default(Active)
  beneficiaries Beneficiary[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

