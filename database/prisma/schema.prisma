model Beneficiary {
  id              String            @id @default(cuid())
  schemeId        String
  scheme          Scheme            @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  citizenId       String
  citizen         Citizen           @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  status          BeneficiaryStatus @default(Pending)
  appliedAt       DateTime          @default(now())
  approvedAt      DateTime?
  disbursedAmount Float?
  disbursedAt     DateTime?
  notes           String?

  @@unique([schemeId, citizenId])
  @@index([status])
  @@index([citizenId])
  @@index([schemeId])
}

// ============================================================
// Engagement
// ============================================================
model Event {
  id          String      @id @default(cuid())
  title       String
  type        EventType   @default(Meeting)
  status      EventStatus @default(Scheduled)
  description String?
  startAt     DateTime
  endAt       DateTime?
  venue       String?

  villageId      String?
  village        Village?      @relation(fields: [villageId], references: [id])
  mandalId       String?
  mandal         Mandal?       @relation(fields: [mandalId], references: [id])
  constituencyId String?
  constituency   Constituency? @relation(fields: [constituencyId], references: [id])

  organizerId           String?
  organizer             Cadre?                 @relation("EventOrganizer", fields: [organizerId], references: [id])
  expectedAttendees     Int                    @default(0)
  qrToken               String?                @unique
  attendees             EventAttendee[]
  activities            Activity[]
  committeeActivityLogs CommitteeActivityLog[]
  electionExpenses      ElectionExpense[]
  electionWorks         ElectionCampaignWork[]

