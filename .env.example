# ===== PostgreSQL =====
POSTGRES_USER=praja
POSTGRES_PASSWORD=praja123
POSTGRES_DB=prajaconnect
POSTGRES_PORT=5432

# Connection string used by Prisma / API.
# Inside Docker the host is "postgres"; from host machine it is "localhost".
DATABASE_URL=postgresql://praja:praja123@postgres:5432/prajaconnect?schema=public
DATABASE_URL_LOCAL=postgresql://praja:praja123@localhost:5432/prajaconnect?schema=public

# ===== Redis =====
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ===== API (NestJS) =====
API_PORT=4000
NODE_ENV=development
# IMPORTANT: generate strong random secrets in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Comma-separated list of allowed web origins.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting (fixed window per client IP).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ===== Web (Next.js) =====
WEB_PORT=3000
# Same-origin /api is proxied to the Nest API by Next.js (see next.config.mjs).
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=http://localhost:4000

# ===== Mobile (Expo) =====
# Use your machine LAN IP so a physical device can reach the Docker API.
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# ===== Adminer =====
ADMINER_PORT=8080

# ===== AI PR Management =====
# OpenAI powers news analysis, report generation, and negative-PR response suggestions.
# Without OPENAI_API_KEY the cycle still ingests RSS feeds using rule-based fallback analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Enable/disable the 4-hour cron (overridden by pr_cron_enabled setting in Admin Settings).
PR_CRON_ENABLED=true
# Default PR response SLA in hours (overridden by pr_response_sla_hours setting).
PR_RESPONSE_SLA_HOURS=24
# Cron schedule: every 4 hours at :00 (00:00, 04:00, 08:00, 12:00, 16:00, 20:00 server time).
# Default seeded RSS sources: Eenadu, Sakshi, Andhra Jyothy, TV9 Telugu (see seedPrManagement).
